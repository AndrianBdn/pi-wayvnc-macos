#!/bin/sh
# Print the current VNC password from /etc/wayvnc/config.
# Root-only because the file is mode 0640 root:vnc once enabled.
set -eu

if [ "$(id -u)" -ne 0 ]; then
    echo "must be run as root" >&2
    exit 1
fi

PW=$(awk -F= '
    /^[[:space:]]*password[[:space:]]*=/ {
        sub(/^[[:space:]]*password[[:space:]]*=[[:space:]]*/, "", $0)
        print
        exit
    }
' /etc/wayvnc/config 2>/dev/null || true)

if [ -z "$PW" ]; then
    echo "No password set in /etc/wayvnc/config." >&2
    echo "Run: sudo pi-wayvnc-macos-enable" >&2
    exit 1
fi

echo "$PW"
